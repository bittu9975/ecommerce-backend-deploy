# Environment Variables Template for E-Commerce Microservices
# Copy this to .env and fill in production values
# DO NOT commit .env file to version control - use platform secrets instead

# ============================================
# PostgreSQL Configuration (Render or Self-Hosted)
# ============================================
POSTGRES_DB=ecommerce
POSTGRES_USER=prod_user_here
POSTGRES_PASSWORD=strong_password_here_change_me

# ============================================
# Spring Boot Database Configuration
# Format: jdbc:postgresql://<HOST>:<PORT>/<DB>
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ecommerce
SPRING_DATASOURCE_USERNAME=prod_user_here
SPRING_DATASOURCE_PASSWORD=strong_password_here_change_me

# ============================================
# Redis Configuration
# ============================================
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ============================================
# JWT Configuration
# CRITICAL: Generate with: openssl rand -hex 32
# MUST be identical across ALL services
# ============================================
JWT_SECRET=GENERATE_THIS_WITH_openssl_rand_hex_32_REPLACE_ME_WITH_64_CHARACTER_HEX

# JWT Token Expiration (milliseconds)
# Default: 86400000 = 24 hours
JWT_EXPIRATION=86400000

# ============================================
# Server Port Configuration (one per service)
# ============================================
# API Gateway
API_GATEWAY_PORT=8080
# Auth Service
AUTH_SERVICE_PORT=8081
# Product Service  
PRODUCT_SERVICE_PORT=8082
# Commerce Service
COMMERCE_SERVICE_PORT=8083

# ============================================
# Service Discovery URLs
# When deployed to production, update these with actual service URLs
# Examples:
# https://api-gateway-xxxxx.onrender.com
# https://auth-service-xxxxx.onrender.com
# ============================================
AUTH_SERVICE_URL=http://auth-service:8081
PRODUCT_SERVICE_URL=http://product-service:8082
COMMERCE_SERVICE_URL=http://commerce-service:8083

# ============================================
# API Gateway - CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# For production:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Commerce Service - Payment Configuration
# ============================================
# Set to 'false' for production (enable real payment processing)
PAYMENT_MOCK_ENABLED=false
# Mock payment success rate: 0-100
PAYMENT_MOCK_SUCCESS_RATE=90

# ============================================
# Commerce Service - Cart Configuration
# ============================================
# Cart session TTL in seconds (default: 86400 = 24 hours)
CART_TTL=86400
# Maximum items allowed in cart
CART_MAX_ITEMS=50

# ============================================
# Notification Configuration
# ============================================
# Email notifications
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_FROM=noreply@yourdomain.com

# SMS notifications (set to false if not configured)
NOTIFICATION_SMS_ENABLED=false

# ============================================
# Logging Configuration
# ============================================
# Valid levels: DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL_ECOMMERCE=INFO

# ============================================
# Spring Profiles (optional but recommended)
# ============================================
# Activate profiles for different environments
# spring.profiles.active=production
